          "registryLoginServer": {
            "value": "[reference('registry').outputs.loginServer.value]"
          },
          "identityId": {
            "value": "[reference('identity').outputs.identityId.value]"
          },
          "identityClientId": {
            "value": "[reference('identity').outputs.identityClientId.value]"
          },
          "identityName": {
            "value": "[reference('identity').outputs.identityName.value]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "11995402580941382844"
            }
          },
          "parameters": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the Container App"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the resource"
              }
            },
            "containerAppEnvId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the Container Apps Environment"
              }
            },
            "registryLoginServer": {
              "type": "string",
              "metadata": {
                "description": "Login server of the Azure Container Registry"
              }
            },
            "identityId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the User-Assigned Managed Identity"
              }
            },
            "identityClientId": {
              "type": "string",
              "metadata": {
                "description": "Client ID of the User-Assigned Managed Identity"
              }
            },
            "identityName": {
              "type": "string",
              "metadata": {
                "description": "Name of the User-Assigned Managed Identity (used as PostgreSQL username)"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2023-05-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('identityId'))]": {}
                }
              },
              "properties": {
                "managedEnvironmentId": "[parameters('containerAppEnvId')]",
                "configuration": {
                  "ingress": {
                    "external": true,
                    "targetPort": 8080,
                    "transport": "auto",
                    "corsPolicy": {
                      "allowedOrigins": [
                        "*"
                      ],
                      "allowedMethods": [
                        "GET",
                        "POST",
                        "PUT",
                        "DELETE",
                        "OPTIONS",
                        "PATCH"
                      ],
                      "allowedHeaders": [
                        "*"
                      ],
                      "allowCredentials": false
                    }
                  },
                  "registries": [
                    {
                      "server": "[parameters('registryLoginServer')]",
                      "identity": "[parameters('identityId')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "photo-album",
                      "image": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "env": [
                        {
                          "name": "SPRING_PROFILES_ACTIVE",
                          "value": "docker"
                        },
                        {
                          "name": "AZURE_CLIENT_ID",
                          "value": "[parameters('identityClientId')]"
                        },
                        {
                          "name": "MANAGED_IDENTITY_NAME",
                          "value": "[parameters('identityName')]"
                        },
                        {
                          "name": "SPRING_CLOUD_AZURE_CREDENTIAL_MANAGED_IDENTITY_ENABLED",
                          "value": "true"
                        },
                        {
                          "name": "SPRING_CLOUD_AZURE_CREDENTIAL_CLIENT_ID",
                          "value": "[parameters('identityClientId')]"
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 1,
                    "maxReplicas": 3
                  }
                }
              }
            }
          ],
          "outputs": {
            "containerAppId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the Container App"
              },
              "value": "[resourceId('Microsoft.App/containerApps', parameters('name'))]"
            },
            "containerAppName": {
              "type": "string",
              "metadata": {
                "description": "Name of the Container App"
              },
              "value": "[parameters('name')]"
            },
            "containerAppFqdn": {
              "type": "string",
              "metadata": {
                "description": "Fully qualified domain name of the Container App"
              },
              "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('name')), '2023-05-01').configuration.ingress.fqdn]"
            }
          }
        }
      },
      "dependsOn": [
        "containerAppEnv",
        "identity",
        "registry"
      ]
    }
  },
