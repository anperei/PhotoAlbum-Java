    "containerAppId": {
      "type": "string",
      "value": "[reference('containerApp').outputs.containerAppId.value]"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference('containerApp').outputs.containerAppFqdn.value]"
    },
    "containerAppEnvName": {
      "type": "string",
      "value": "[reference('containerAppEnv').outputs.envName.value]"
    },
    "containerAppEnvId": {
      "type": "string",
      "value": "[reference('containerAppEnv').outputs.envId.value]"
    },
    "postgresqlServerName": {
      "type": "string",
      "value": "[reference('postgresql').outputs.serverName.value]"
    },
    "postgresqlServerFqdn": {
      "type": "string",
      "value": "[reference('postgresql').outputs.serverFqdn.value]"
    }
  }
